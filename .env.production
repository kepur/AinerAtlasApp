APP_ENV=production
DEBUG=false

# Database — PostgreSQL required in production
DATABASE_URL=postgresql://ainerspeak:CHANGE_ME@localhost:5432/ainerspeak

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth — MUST be a strong random secret
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS — restrict to actual domain(s)
CORS_ORIGINS=https://app.ainerspeak.com,https://admin.ainerspeak.com

# AI Providers
DEFAULT_LLM_PROVIDER=openai
DEFAULT_VOICE_PROVIDER=openai

# API Key encryption — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_FERNET

# Seed admin account — change password after first login
INITIAL_ADMIN_EMAIL=admin@ainerspeak.com
INITIAL_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
