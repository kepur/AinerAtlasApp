# Security — production should set PLAINTEXT_API_KEYS=false and a fixed ENCRYPTION_KEY
PLAINTEXT_API_KEYS=true
ENCRYPTION_KEY=

# Local ports (Docker Compose host mapping — left side is customizable, see DEPLOY.md §12)
# API=7070  Web=7075  Admin=7072  Postgres=7073  Redis=7074
# Vite dev also uses Web=7075; Admin dev=7076
# After changing host ports, update CORS_ORIGINS in .env / .env.development

# AI Providers — prefer Admin UI / DB; .env is fallback only when admin is empty
# Configure in Admin → AI Providers (keys, endpoints) and Runtime Routing (defaults)
DEFAULT_LLM_PROVIDER=mock
DEFAULT_VOICE_PROVIDER=mock
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# DashScope / 阿里云百炼 MAAS — used only when not configured in Admin
# 获取 API Key: https://help.aliyun.com/zh/model-studio/get-api-key
DASHSCOPE_API_KEY=
DASHSCOPE_WORKSPACE_ID=
# 示例（新加坡 MAAS 工作空间）:
# DASHSCOPE_COMPATIBLE_BASE_URL=https://ws-xxx.ap-southeast-1.maas.aliyuncs.com/compatible-model/v1
# DASHSCOPE_HTTP_BASE_URL=https://ws-xxx.ap-southeast-1.maas.aliyuncs.com/api/v1
# DASHSCOPE_WEBSOCKET_BASE_URL=wss://ws-xxx.ap-southeast-1.maas.aliyuncs.com/api-ws/v1/inference
DASHSCOPE_COMPATIBLE_BASE_URL=
DASHSCOPE_HTTP_BASE_URL=
DASHSCOPE_WEBSOCKET_BASE_URL=
DASHSCOPE_WS_URL=
REALTIME_ASR_PROVIDER=auto
DASHSCOPE_ASR_MODEL=fun-asr-realtime
DASHSCOPE_ASR_SAMPLE_RATE=16000
DASHSCOPE_ASR_MAX_SENTENCE_SILENCE=800
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
DASHSCOPE_EMBEDDING_DIMENSION=1024
DEFAULT_EMBEDDING_PROVIDER=dashscope-embedding
