APP_ENV=development
DEBUG=true

# Database — SQLite for local development
DATABASE_URL=sqlite:///./ainerspeak.db

# Redis — optional for development (features degrade gracefully)
# Docker host mapping: redis://localhost:7074/0
REDIS_URL=redis://localhost:7074/0

# Auth
JWT_SECRET=dev-only-not-for-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS — allow Vite dev servers and Docker frontends
CORS_ORIGINS=http://localhost:7075,http://localhost:7072,http://localhost:7076

# AI Providers — use .env for secrets; Docker also loads ../.env when present
DEFAULT_LLM_PROVIDER=qwen
DEFAULT_VOICE_PROVIDER=dashscope
REALTIME_ASR_PROVIDER=dashscope

# Alibaba Cloud MAAS workspace (ap-southeast-1)
DASHSCOPE_WORKSPACE_ID=ws-84dldz0dg9w204h9
DASHSCOPE_COMPATIBLE_BASE_URL=https://ws-84dldz0dg9w204h9.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
DASHSCOPE_HTTP_BASE_URL=https://ws-84dldz0dg9w204h9.ap-southeast-1.maas.aliyuncs.com/api/v1
DASHSCOPE_WEBSOCKET_BASE_URL=wss://ws-84dldz0dg9w204h9.ap-southeast-1.maas.aliyuncs.com/api-ws/v1/inference
DASHSCOPE_WS_URL=wss://ws-84dldz0dg9w204h9.ap-southeast-1.maas.aliyuncs.com/api-ws/v1/inference
DASHSCOPE_ASR_MODEL=fun-asr-realtime
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
DASHSCOPE_EMBEDDING_DIMENSION=1024

# Development: store Admin API keys as plaintext in DB (no Fernet). Production should use PLAINTEXT_API_KEYS=false.
PLAINTEXT_API_KEYS=true
ENCRYPTION_KEY=-GFLx_y5r5rbYMTbkcY1gzUIc1mubmHkIzms51UQRUw=

# Seed admin account
INITIAL_ADMIN_EMAIL=admin@ainerspeak.com
INITIAL_ADMIN_PASSWORD=ChangeMe123!
