{
  "name": "ainerspeak",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/web",
    "apps/admin",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "dev:admin": "npm --workspace apps/admin run dev",
    "docker:up": "docker compose up -d --build",
    "docker:rebuild": "docker compose build --no-cache api web admin && docker compose up -d --force-recreate",
    "docker:prod": "docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build",
    "snapshot:export": "bash scripts/export-deploy-snapshot.sh",
    "snapshot:import": "bash scripts/import-deploy-snapshot.sh",
    "build": "npm --workspaces --if-present run build",
    "lint": "npm --workspaces --if-present run lint"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  }
}
